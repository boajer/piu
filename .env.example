# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Target language for translation (e.g. English, Spanish, French, Russian, etc.)
TARGET_LANGUAGE=English

# Optional: only process voice messages forwarded from specific chats
# Leave empty to process ALL incoming voice messages
# ALLOWED_CHATS=Chat Name 1,Chat Name 2

# Optional: whitelist of phone numbers allowed to trigger the bot (country code + digits, no +)
# Leave empty to allow ALL senders
# ALLOWED_SENDERS=15551234567,447700900000

# Cloud deployment: set your WhatsApp number to get a pairing code in logs instead of a QR code
# WA_PHONE_NUMBER=15551234567   # country code + digits, no +

# Port for the HTTP health check endpoint (cloud platforms require this)
# PORT=3000
