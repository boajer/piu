# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Target language for translation (e.g. English, Spanish, French, Russian, etc.)
TARGET_LANGUAGE=English

# Optional: only process voice messages forwarded from specific chats
# Leave empty to process ALL incoming voice messages
# ALLOWED_CHATS=Chat Name 1,Chat Name 2
